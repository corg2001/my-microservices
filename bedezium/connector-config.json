{
  "name": "employee-salary-cdc",
  "config": {
    "connector.class": "io.debezium.connector.sqlserver.SqlServerConnector",

    "database.hostname": "my-microservices-sql.database.windows.net",
    "database.port": "1433",
    "database.user": "sqladmin",
    "database.password": "${file:/opt/kafka/secrets/debezium-secrets.properties:database.password}",
    "database.names": "my-microservices-db",
    "database.encrypt": "true",
    "database.trustServerCertificate": "false",

    "table.include.list": "dbo.Employees",
    "column.include.list": "dbo.Employees.Id,dbo.Employees.Name,dbo.Employees.Salary",

    "topic.prefix": "cdc",

    "database.history.kafka.bootstrap.servers": "${file:/opt/kafka/secrets/debezium-secrets.properties:eventhubs.bootstrap.servers}",
    "database.history.kafka.topic": "cdc.schema-history",
    "database.history.producer.security.protocol": "SASL_SSL",
    "database.history.producer.sasl.mechanism": "PLAIN",
    "database.history.producer.sasl.jaas.config": "${file:/opt/kafka/secrets/debezium-secrets.properties:eventhubs.jaas.config}",
    "database.history.consumer.security.protocol": "SASL_SSL",
    "database.history.consumer.sasl.mechanism": "PLAIN",
    "database.history.consumer.sasl.jaas.config": "${file:/opt/kafka/secrets/debezium-secrets.properties:eventhubs.jaas.config}",

    "offset.storage": "org.apache.kafka.connect.storage.FileOffsetBackingStore",

    "snapshot.mode": "initial",

    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.unwrap.delete.handling.mode": "rewrite"
  }
}